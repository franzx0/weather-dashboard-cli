{
  "name": "weather-dashboard-cli",
  "version": "1.0.0",
  "description": "A command-line weather dashboard that fetches data from OpenWeatherMap and REST Countries APIs",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "keywords": ["weather", "cli", "node", "api"],
  "author": "Your Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "dotenv": "^16.3.1",
    "joi": "^17.11.0",
    "ora": "^5.4.1",
    "table": "^6.8.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "axios-mock-adapter": "^1.22.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
    }
  }
}
